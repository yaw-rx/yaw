{
  "name": "@yaw-rx/bench",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "js-framework-benchmark": {
    "frameworkVersion": "0.1.0",
    "frameworkHomeURL": "https://github.com/nicksrandall/yaw",
    "language": "TypeScript"
  },
  "scripts": {
    "prepare": "ts-patch install",
    "dev": "vite",
