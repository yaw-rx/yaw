    "bench": "bash setup-harness.sh && bash run-bench.sh",
    "bench:clean": "rm -rf js-framework-benchmark dist",
    "bench:results": "bash print-results.sh",
    "bench:dev": "node timing-test.mjs"
  },
  "dependencies": {
    "rxjs": "8.0.0-alpha.14",
    "@yaw-rx/core": "file:../yaw",
    "@yaw-rx/transformer": "file:../yaw-transformer"
  },
  "devDependencies": {
    "ts-patch": "^3.3.0",
    "vite": "^5.0.0",
    "@yaw-rx/vite": "file:../yaw-vite",
    "@yaw-rx/ts-plugin": "file:../yaw-ts-plugin"
  }
}
