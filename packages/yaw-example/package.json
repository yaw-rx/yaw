{
  "name": "@yaw-rx/example",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "ts-patch install",
    "dev": "vite",
    "build": "rm -rf dist && vite build",
    "build:vite": "rm -rf dist && vite build",
    "build:rollup": "rm -rf dist/rollup && rollup -c rollup.config.js",
    "build:esbuild": "rm -rf dist/esbuild && node esbuild.config.js",
    "build:webpack": "rm -rf dist/webpack && webpack --config webpack.config.js",
    "build:ssg": "yaw-ssg dist public",
    "ssl:generate": "mkdir -p ssl && openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout ssl/key.pem -out ssl/cert.pem -subj '/CN=localhost'",
    "docker:build:dev": "docker compose -f compose.dev.yaml build --no-cache",
    "docker:build:prod": "docker compose build --no-cache",
    "docker:up:dev": "docker compose -f compose.dev.yaml up --remove-orphans; docker compose -f compose.dev.yaml down --volumes --remove-orphans",
    "docker:up:prod": "docker compose up",
    "docker:down:dev": "docker compose -f compose.dev.yaml down --volumes --remove-orphans",
    "docker:down:prod": "docker compose down",
    "typecheck": "tsc --build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "vscode:install": "cd node_modules/@yaw-rx/vscode && npm run build && ln -sfn \"$(pwd)\" \"$HOME/.vscode/extensions/yaw-rx.yaw-vscode\""
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "decimal.js": "^10.6.0",
    "rxjs": "8.0.0-alpha.14",
    "viem": "^2.48.4",
    "@yaw-rx/core": "file:../yaw",
    "@yaw-rx/transformer": "file:../yaw-transformer"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "esbuild": "^0.25.0",
    "esbuild-loader": "^4.0.0",
    "html-webpack-plugin": "^5.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-esbuild": "^6.0.0",
    "ts-patch": "^3.3.0",
    "vite": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^6.0.0",
    "@yaw-rx/vite": "file:../yaw-vite",
    "@yaw-rx/rollup": "file:../yaw-rollup",
    "@yaw-rx/esbuild": "file:../yaw-esbuild",
    "@yaw-rx/webpack": "file:../yaw-webpack",
    "@yaw-rx/ssg": "file:../yaw-ssg",
    "@yaw-rx/ts-plugin": "file:../yaw-ts-plugin",
    "@eslint/js": "^9.39.0",
    "eslint": "^9.39.0",
    "typescript-eslint": "^8.59.0",
    "prettier": "^3.8.0",
    "@yaw-rx/vscode": "file:../yaw-vscode"
  }
}
