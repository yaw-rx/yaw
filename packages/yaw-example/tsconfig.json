{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "ESNext.Temporal"],
    "outDir": "./dist",
    "rootDir": "./src",
    "plugins": [
      { "name": "yaw-ts-plugin" },
      { "transform": "yaw-transformer", "type": "program" }
    ],
    "paths": {
      "yaw": ["../yaw/src/index.ts"],
      "yaw-common": ["../yaw-common/src/index.ts"],
      "yaw-transformer": ["../yaw-transformer/src/index.ts"]
    }
  },
  "references": [
    { "path": "../yaw-common" },
    { "path": "../yaw" },
    { "path": "../yaw-transformer" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
