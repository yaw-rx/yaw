{
    "name": "@yaw-rx/ssg",
    "version": "0.1.1",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "files": [
        "dist",
        "src"
    ],
    "type": "module",
    "bin": {
        "yaw-ssg": "./dist/cli.js"
    },
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch --preserveWatchOutput",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --check src/",
        "format:fix": "prettier --write src/"
    },
    "dependencies": {
        "prettier": "^3.0.0",
        "puppeteer-core": "^24.0.0",
        "sirv": "^3.0.0",
        "@yaw-rx/core": "*"
    }
}
