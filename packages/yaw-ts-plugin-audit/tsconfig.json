{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true,
    "plugins": [
      { "name": "yaw-ts-plugin" }
    ],
    "paths": {
      "yaw": ["../yaw/src/index.ts"]
    }
  },
  "references": [
    { "path": "../yaw" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
