{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/cjs",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "verbatimModuleSyntax": false,
    "ignoreDeprecations": "6.0",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "references": [
    { "path": "../yaw-common" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
