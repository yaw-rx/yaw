{
  "name": "@yaw-rx/common",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./escape": {
      "types": "./dist/escape.d.ts",
      "import": "./dist/escape.js",
      "default": "./dist/escape.js"
    },
    "./tags": {
      "types": "./dist/tags.d.ts",
      "import": "./dist/tags.js",
      "default": "./dist/tags.js"
    },
    "./marshaller": {
      "types": "./dist/marshaller.d.ts",
      "import": "./dist/marshaller.js",
      "default": "./dist/marshaller.js"
    },
    "./transform": {
      "types": "./dist/transform.d.ts",
      "import": "./dist/transform.js",
      "default": "./dist/transform.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@mdn/browser-compat-data": "^7.3.12",
    "@types/jsdom": "^28.0.1",
    "jsdom": "^29.0.2"
  }
}
