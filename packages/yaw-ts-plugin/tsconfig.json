{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "module": "CommonJS",
    "moduleResolution": "node10",
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
