{
  "name": "@yaw-rx/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./router": {
      "import": "./dist/router.js",
      "types": "./dist/router.d.ts"
    },
    "./router/outlet": {
      "import": "./dist/components/rx-router-outlet.js",
      "types": "./dist/components/rx-router-outlet.d.ts"
    },
    "./directives/rx-if": {
      "import": "./dist/directives/rx-if.js",
      "types": "./dist/directives/rx-if.d.ts"
    },
    "./directives/rx-for": {
      "import": "./dist/directives/rx-for.js",
      "types": "./dist/directives/rx-for.d.ts"
    },
    "./hydrate/bootstrap": {
      "import": "./dist/hydrate/bootstrap.js",
      "types": "./dist/hydrate/bootstrap.d.ts"
    },
    "./hydrate/resolve": {
      "import": "./dist/hydrate/resolve.js",
      "types": "./dist/hydrate/resolve.d.ts"
    },
    "./hydrate/state": {
      "import": "./dist/hydrate/state.js",
      "types": "./dist/hydrate/state.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/"
  },
  "dependencies": {
    "@yaw-rx/common": "*",
    "rxjs": "8.0.0-alpha.14"
  }
}
