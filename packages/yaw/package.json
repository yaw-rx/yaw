{
  "name": "@yaw-rx/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./router": {
      "import": "./dist/router.js",
      "types": "./dist/router.d.ts"
    },
    "./router/outlet": {
      "import": "./dist/components/rx-router-outlet.js",
      "types": "./dist/components/rx-router-outlet.d.ts"
    },
    "./directives/rx-if": {
      "import": "./dist/directives/rx-if.js",
      "types": "./dist/directives/rx-if.d.ts"
    },
    "./directives/rx-for": {
      "import": "./dist/directives/rx-for.js",
      "types": "./dist/directives/rx-for.d.ts"
    },
    "./ssg/hydrate/load-hydrate-state": {
      "import": "./dist/ssg/hydrate/load-hydrate-state.js",
      "types": "./dist/ssg/hydrate/load-hydrate-state.d.ts"
    },
    "./ssg/hydrate/get-component-hydrate-state": {
      "import": "./dist/ssg/hydrate/get-component-hydrate-state.js",
      "types": "./dist/ssg/hydrate/get-component-hydrate-state.d.ts"
    },
    "./ssg/hydrate/get-service-hydrate-state": {
      "import": "./dist/ssg/hydrate/get-service-hydrate-state.js",
      "types": "./dist/ssg/hydrate/get-service-hydrate-state.d.ts"
    },
    "./ssg/hydrate/strip-ssg-attributes": {
      "import": "./dist/ssg/hydrate/strip-ssg-attributes.js",
      "types": "./dist/ssg/hydrate/strip-ssg-attributes.d.ts"
    },
    "./ssg/hydrate/hydration-state": {
      "import": "./dist/ssg/hydrate/hydration-state.js",
      "types": "./dist/ssg/hydrate/hydration-state.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@yaw-rx/common": "*",
    "rxjs": "8.0.0-alpha.14"
  }
}
