{
  "name": "yaw-vscode",
  "displayName": "YAW",
  "description": "HTML and CSS highlighting and intellisense inside @Component template and styles",
  "version": "0.1.0",
  "publisher": "yaw-rx",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Programming Languages"],
  "main": "./dist/extension.js",
  "activationEvents": ["onLanguage:typescript", "onLanguage:typescriptreact"],
  "contributes": {
    "grammars": [
      {
        "scopeName": "yaw.template.html",
        "path": "./syntaxes/yaw-template-html.tmLanguage.json",
        "injectTo": ["source.ts", "source.tsx"],
        "embeddedLanguages": { "meta.embedded.block.html": "html" }
      },
      {
        "scopeName": "yaw.template.css",
        "path": "./syntaxes/yaw-template-css.tmLanguage.json",
        "injectTo": ["source.ts", "source.tsx"],
        "embeddedLanguages": { "meta.embedded.block.css": "css" }
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node"
  },
  "dependencies": {
    "vscode-html-languageservice": "^5.3.0",
    "vscode-css-languageservice": "^6.3.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.25.0"
  }
}
