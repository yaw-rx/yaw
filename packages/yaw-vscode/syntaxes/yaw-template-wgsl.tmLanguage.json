{
  "scopeName": "yaw.template.wgsl",
  "injectionSelector": "L:source.ts -comment, L:source.tsx -comment",
  "patterns": [
    {
      "begin": "(?:\\b)(wgsl)\\s*(`)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.tagged-template.ts" },
        "2": { "name": "punctuation.definition.string.template.begin.ts" }
      },
      "end": "(`)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.template.end.ts" }
      },
      "contentName": "meta.embedded.block.wgsl",
      "patterns": [
        {
          "begin": "\\$\\{",
          "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.ts" } },
          "end": "\\}",
          "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.ts" } },
          "name": "meta.template.expression.ts",
          "patterns": [{ "include": "source.ts" }]
        },
        { "include": "source.wgsl" }
      ]
    },
    {
      "begin": "/\\*\\s*wgsl\\s*\\*/\\s*(`)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.template.begin.ts" }
      },
      "end": "(`)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.template.end.ts" }
      },
      "contentName": "meta.embedded.block.wgsl",
      "patterns": [
        {
          "begin": "\\$\\{",
          "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.ts" } },
          "end": "\\}",
          "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.ts" } },
          "name": "meta.template.expression.ts",
          "patterns": [{ "include": "source.ts" }]
        },
        { "include": "source.wgsl" }
      ]
    }
  ]
}
