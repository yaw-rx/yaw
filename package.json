{
  "name": "yaw-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build packages/yaw-common packages/yaw packages/yaw-transformer && npm run build -w packages/yaw-example",
    "typecheck": "tsc --build --dry packages/yaw-common packages/yaw packages/yaw-transformer",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.1.1",
    "@types/node": "^20.12.7",
    "eslint": "^9.1.1",
    "prettier": "^3.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
