{
  "name": "yaw-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/yaw-common",
    "packages/yaw-transformer",
    "packages/yaw-ts-plugin",
    "packages/yaw-ts-plugin-audit",
    "packages/yaw",
    "packages/yaw-ssg"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:watch": "tsc --build --watch --preserveWatchOutput",
    "dev": "trap 'kill 0' EXIT; npm run build:watch & npm run dev --prefix packages/yaw-example & wait",
    "typecheck": "tsc --build --dry packages/yaw-common packages/yaw packages/yaw-transformer",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.1.1",
    "@types/node": "^20.12.7",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.1.1",
    "prettier": "^3.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
